{
  "name": "eduvulcan-cli",
  "version": "0.1.0",
  "description": "Standalone CLI for logging into EduVulcan via browser and fetching school data via API",
  "type": "module",
  "bin": {
    "eduvulcan-fetch": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "fetch": "tsx src/cli.ts fetch",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "dotenv": "^17.2.3",
    "playwright": "^1.58.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
